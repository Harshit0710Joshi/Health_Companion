generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String        @unique
  password     String
  appointments Appointment[]
  records      Record[]
  vitals       Vital?
  chatMessages ChatMessage[]
  createdAt    DateTime      @default(now())
}

model Doctor {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  name           String
  email          String        @unique @default("doctor@medicare.local")
  password       String        @default("$2a$10$abcdefghijklmnopqrstuv")
  specialization String
  rating         Float
  experience     String
  fee            String
  initials       String
  color          String
  appointments   Appointment[]
}

model Appointment {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  date     String
  time     String
  status   String @default("Scheduled")
  notes    String @default("")
  roomId   String @default("")
  userId   String @db.ObjectId
  user     User   @relation(fields: [userId], references: [id])
  doctorId String @db.ObjectId
  doctor   Doctor @relation(fields: [doctorId], references: [id])
}

model Record {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String
  date        String
  type        String
  userId      String @db.ObjectId
  user        User   @relation(fields: [userId], references: [id])
}

model Vital {
  id            String @id @default(auto()) @map("_id") @db.ObjectId
  heartRate     String
  bloodPressure String
  sugarLevel    String
  medications   String
  userId        String @unique @db.ObjectId
  user          User   @relation(fields: [userId], references: [id])
}

model ChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  role      String
  text      String
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}